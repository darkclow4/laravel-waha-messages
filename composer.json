{
    "name": "darkclow4/laravel-waha-messages",
    "description": "Laravel integration package for WAHA (WhatsApp HTTP API)",
    "keywords": [
        "laravel",
        "waha",
        "whatsapp",
        "messaging"
    ],
    "authors": [
        {
            "name": "Muhammad Irfan Muttaqin",
            "email": "irfan.140895@gmail.com"
        }
    ],
    "homepage": "https://github.com/darkclow4/laravel-waha-messages",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.3",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelWaha\\WahaMessages\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelWaha\\WahaMessages\\WahaServiceProvider"
            ],
            "aliases": {
                "Waha": "LaravelWaha\\WahaMessages\\Facades\\Waha"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}